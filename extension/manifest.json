{
  "manifest_version": 3,
  "name": "Assistente Zweb",
  "version": "1.1",
  "description": "Bloqueios e automacoes para fluxos administrativos, fiscais e de notas na Zweb.",
  "permissions": ["contextMenus", "debugger", "downloads", "offscreen", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://zweb.com.br/*",
    "https://compufour.s3.amazonaws.com/production/uploads/nfe/*",
    "https://compufour.s3.amazonaws.com/production/uploads/reports/report/*",
    "https://www.fsist.com.br/*",
    "https://fsist.com.br/*",
    "https://www.nfe.fazenda.gov.br/*",
    "https://nfe.fazenda.gov.br/*"
  ],
  "action": {
    "default_title": "Assistente Zweb",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://zweb.com.br/*"],
      "js": ["features.js", "note-assistant.js", "fiscal-value-settings.js", "purchase-value-sync.js", "stock-price-simulation.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.fsist.com.br/*",
        "https://fsist.com.br/*",
        "https://www.nfe.fazenda.gov.br/*",
        "https://nfe.fazenda.gov.br/*"
      ],
      "js": ["features.js", "note-assistant.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://compufour.s3.amazonaws.com/production/uploads/reports/report/*"
      ],
      "js": ["features.js", "report-adjustments.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["https://zweb.com.br/*"]
    }
  ]
}
